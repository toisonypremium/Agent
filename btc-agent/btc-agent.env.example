# Copy to $HOME/btc-agent.env on the device if you accept local env-file risk.
# Never commit real secrets. Never paste real keys into chat/logs.

# Runtime mode: paper | live-proof | live-canary-auto
export BTC_AGENT_MODE=paper
export BTC_AGENT_CONFIG=config.yaml
export BTC_AGENT_LOG_DIR=logs

# Required only for live-canary-auto real scheduler management.
export BTC_AGENT_ALLOW_AUTO_LIVE=false

# OKX live credentials. Use IP whitelist and rotate any key pasted elsewhere.
export OKX_API_KEY="PASTE_OKX_API_KEY_HERE"
export OKX_API_SECRET="PASTE_OKX_API_SECRET_HERE"
export OKX_API_PASSPHRASE="PASTE_OKX_API_PASSPHRASE_HERE"

# Optional Telegram notifications.
export TELEGRAM_TOKEN="PASTE_TELEGRAM_BOT_TOKEN_HERE"
export TELEGRAM_CHAT_ID="PASTE_TELEGRAM_CHAT_ID_HERE"
