[Unit]
Description=BTC Agent read-only Web Console
After=network-online.target btc-agent-immutable.service
Wants=network-online.target

[Service]
Type=simple
Environment=BTC_AGENT_WEB_DB_PATH=%h/btc-agent/runtime/data/btc_agent.db
Environment=BTC_AGENT_WEB_STATIC_DIR=%h/btc-agent/web-console/current/static
Environment=BTC_AGENT_WEB_HEALTH_DIR=%h/btc-agent/runtime/observer
Environment=BTC_AGENT_WEB_LISTEN_ADDR=127.0.0.1:8787
Environment=BTC_AGENT_CF_ACCESS_TEAM_DOMAIN=linhbot.cloudflareaccess.com
Environment=BTC_AGENT_CF_ACCESS_AUD=5694969811a524830560d29e7e913a4048c0672e2afcb406f0a82e30fa38df84
Environment=BTC_AGENT_WEB_PUBLIC_ORIGIN=https://console.linhbot.xyz
Environment=BTC_AGENT_WEB_OPERATOR_IDENTITY=llthtt1@gmail.com
ExecStart=%h/btc-agent/web-console/current/web-console
Restart=on-failure
RestartSec=10
TimeoutStopSec=30
KillSignal=SIGTERM
UMask=0077
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only

[Install]
WantedBy=default.target
