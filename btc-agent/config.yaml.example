app:
  mode: "paper"
  timezone: "Asia/Ho_Chi_Minh"
  daily_run_time: "08:00"
  reconcile_interval_minutes: 15

storage:
  path: "data/btc_agent.db"

portfolio:
  base_currency: "USDT"
  total_capital: 1000
  allocation:
    ETHUSDT: 0.35
    SOLUSDT: 0.45
    RENDERUSDT: 0.20
  reserve_cash_ratio: 0.05

risk:
  max_total_deployment_per_cycle: 0.70
  max_single_asset_deployment: 0.45
  min_reward_risk: 3.0
  stop_on_panic_selling: true
  disable_relative_strength_filter: false
  relative_strength_lookback_days: 14
  min_relative_strength: -0.03
  min_asset_momentum: -0.05
  disable_rotation_score_filter: false
  min_rotation_score: 0.55
  max_rotation_rank: 2
  strict_rotation_rank: false
  disable_asset_flow_entry_filter: false
  min_asset_flow_bull_score: 0.25
  allow_neutral_reclaim_entry: true
  strict_asset_flow_entry: false
  flow_bear_hard_block_score: 0.45
  max_total_equity_drawdown_pct: 0.08
  max_daily_realized_loss_pct: 0.03
  min_scout_reward_risk: 1.5
  allow_scout_in_downtrend: true
  no_futures: true
  no_leverage: true
  spot_limit_only: true

btc_cycle:
  stress_price_reference: 28000
  use_dynamic_cycle_zone: true
  require_reclaim_before_major_buy: true

data:
  binance_base_url: "https://api.binance.com"
  symbols:
    btc: "BTCUSDT"
    assets:
      - "ETHUSDT"
      - "SOLUSDT"
      - "RENDERUSDT"
    research_universe:
      - "LINKUSDT"
      - "AVAXUSDT"
      - "NEARUSDT"
  intervals:
    - "4h"
    - "1d"
    - "1w"
  candle_limit: 500

maintenance:
  enabled: true
  scheduler_enabled: true
  scheduler_time: "03:30"
  report_retention_days: 30
  event_retention_days: 90
  max_report_files: 50
  max_closed_paper_orders: 500
  max_candles_per_symbol_interval: 1000
  max_analysis_rows: 500
  max_plan_rows: 500
  wal_checkpoint_on_maintenance: true

notify:
  enabled: false
  provider: "telegram"
  telegram_chat_id: ""
  ntfy_topic: ""

ai:
  enabled: false
  provider: "openai_compatible"
  model: "Claw"
  base_url_env: "ANTHROPIC_BASE_URL"
  api_key_env: "ANTHROPIC_API_KEY"
  max_tokens: 900 # legacy fallback only
  max_tokens_by_purpose:
    ai_watch: 1200
    hermes_narrative: 1400
    hermes_operator_decision: 900
    research_brief: 2000
    expert_research: 3200
    interactive_question: 1600
    scheduler_telegram_formatter: 2000
  temperature: 0
  telegram_enabled: false # Telegram là kênh thông báo tùy chọn
  hermes_interval_minutes: 60   # how often Hermes AI cycle runs; 0 = only on --run-now
  hermes_fresh_audit_max_minutes: 30
  hermes_min_alert_gap_minutes: 30
  hermes_event_driven_enabled: true
  hermes_telegram_interactive: false

research:
  enabled: false
  brief_interval_minutes: 360
  max_sources_per_cycle: 20
  request_timeout_seconds: 12
  rss:
    enabled: true
    feeds:
      - "https://www.coindesk.com/arc/outboundfeeds/rss/"
      - "https://cointelegraph.com/rss"

monitoring:
  enabled: true
  market_scan_interval_minutes: 15
  telegram_digest_interval_minutes: 60
  notify_on_state_change: true
  notify_on_critical: true
  critical_repeat_minutes: 60
  max_consecutive_scan_errors: 3

microstructure:
  enabled: true
  fetch_on_market_watch: true
  require_fresh_for_active: true
  binance_spot_base_url: "https://api.binance.com"
  binance_futures_base_url: "https://fapi.binance.com"
  interval: "5m"
  lookback_limit: 120
  max_age_minutes: 30
  orderbook_depth_limit: 100
  min_fresh_symbols_required: 4

live:
  enabled: false
  exchange: "okx"
  api_key_env: "OKX_API_KEY"
  api_secret_env: "OKX_API_SECRET"
  api_passphrase_env: "OKX_API_PASSPHRASE"
  max_order_notional_usdt: 10
  min_account_free_usdt: 20
  require_post_only: true
  require_manual_confirm: true
  auto_execute: false
  live_auto_mode: false
  live_auto_max_notional_usdt: 2.0
  first_order_quarantine_enabled: true
  first_order_max_notional_usdt: 1.0
  first_order_require_dry_run: true
  order_management_enabled: false
  max_auto_layers_per_asset: 3
  max_open_live_orders_per_asset: 3
  max_open_live_orders_total: 9
  max_live_notional_per_order_usdt: 2.0
  max_live_notional_per_asset_usdt: 6.0
  max_live_notional_total_usdt: 18.0
  cancel_if_plan_not_active: true
  cancel_if_price_above_discount_zone_pct: 0.02
  replace_if_price_drift_pct: 0.01
  cancel_stale_after_minutes: 240
  cancel_on_btc_permission_not_allowed: true
  supervisor_enabled: false
  management_interval_minutes: 15
  audit_interval_minutes: 60      # how often live-auto-audit runs; 0 = only on --run-now
  heartbeat_interval_minutes: 360
  auto_halt_after_errors: 3
  notify_on_no_action: false
  proof_only: true
  liquidity_gate_enabled: true
  require_orderbook_liquidity: true
  max_spread_bps: 20
  max_slippage_bps: 15
  min_bid_depth_to_order_ratio: 3
  max_order_to_avg_5m_quote_volume_pct: 0.2
  mm_gate_samples: 3
  mm_gate_sample_delay_ms: 500

execution:
  paper_trading: true
  real_trading_enabled: false
  order_expiry_hours: 48
  layer_distribution:
    - 0.25
    - 0.35
    - 0.40

exit:
  enabled: false
  take_profit_pct: 0.30
  partial_exit_pct: 0.50
  trailing_activate_pct: 0.20
  trailing_distance_pct: 0.08
  time_stop_days: 90
  min_pnl_for_time_stop: 0.0

# Hermes strategy authority. Keep observe/shadow until audited.
hermes_operator:
  enabled: false
  mode: "observe" # observe | shadow | canary | autonomous
  decision_ttl_seconds: 120
  min_confidence: 0.60
  max_actions_per_cycle: 3
  max_probe_notional_usdt: 5
  max_action_notional_usdt: 10
  max_portfolio_exposure_usdt: 20
